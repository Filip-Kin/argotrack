API_KEY="PRIVATE KEY"
CLIENT_EMAIL="example@developer.gserviceaccount.com"
SPREADSHEET_ID="1234"
# Timezone used to bucket punches into per-day columns (IANA name). Default America/New_York.
TIMEZONE="America/New_York"
PORT=3000
# Coach dashboard password (guards /report, /roster, /seasons, /checklist, /signoutall).
COACH_PASSWORD="change-me"
# Kiosk PIN that signs everyone out at once. Default 9999.
SIGNOUT_ALL_PIN="9999"
